{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "INTP Study Manager",
  "version": "0.1.0",
  "identifier": "com.intp.study.manager",
  "build": {
    "beforeDevCommand": "cd ../../frontend && npm run dev",
    "beforeBuildCommand": "cd ../../frontend && npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "INTP Study Manager",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
